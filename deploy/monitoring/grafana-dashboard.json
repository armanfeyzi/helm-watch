{
  "id": null,
  "uid": "helm-watch-overview",
  "title": "Helm Watch Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "style": "dark",
  "tags": [
    "helm-watch",
    "kubernetes",
    "helm"
  ],
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(helm_chart_info, namespace)",
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Outdated Charts",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(helm_chart_outdated{namespace=~\"$namespace\"})",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Tracked Charts",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "count(helm_chart_info{namespace=~\"$namespace\"})",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "table",
      "title": "Chart Versions Matrix",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 4 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "max by (app, namespace, chart, repo, source_kind, current_version, latest_version, deployment_type, status) (helm_chart_info{namespace=~\"$namespace\"})",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "status"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 130
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "up_to_date": {
                        "color": "dark-green",
                        "text": "up to date"
                      },
                      "outdated": {
                        "color": "dark-red",
                        "text": "outdated"
                      },
                      "unknown": {
                        "color": "dark-yellow",
                        "text": "unknown"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducers": []
        }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "namespace": true
            },
            "indexByName": {
              "status": 0,
              "app": 1,
              "current_version": 2,
              "latest_version": 3,
              "chart": 4,
              "repo": 5,
              "deployment_type": 6,
              "source_kind": 7
            },
            "renameByName": {
              "current_version": "current ver",
              "latest_version": "latest version",
              "deployment_type": "deployment type",
              "source_kind": "source kind"
            }
          }
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Outdated Charts by Namespace",
      "gridPos": { "h": 4, "w": 16, "x": 8, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum by (namespace) (helm_chart_outdated{namespace=~\"$namespace\"})",
          "refId": "A"
        }
      ],
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Reconcile Duration (seconds)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "helm_watch_reconcile_duration_seconds",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Reconcile Errors (rate)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 16 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "rate(helm_watch_reconcile_errors_total[5m])",
          "refId": "A"
        }
      ]
    }
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  }
}
